# Before running pnpm install, manually delete:
#   focus-flight/node_modules/
#   focus-flight/apps/mobile/node_modules/
#   focus-flight/apps/mobile/android/.cxx/
#   focus-flight/apps/mobile/android/app/.cxx/ (if exists)
# Then run: npx pnpm@10.28.0 install
shamefully-hoist=true
store-dir=C:\p
virtual-store-dir=C:\p\vs
node-linker=isolated
